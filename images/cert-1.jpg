<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 400">
  <defs>
    <linearGradient id="g1" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#1e3a5f"/>
      <stop offset="100%" stop-color="#2563eb"/>
    </linearGradient>
  </defs>
  <rect width="600" height="400" fill="url(#g1)"/>
  <rect x="20" y="20" width="560" height="360" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="2" rx="8"/>
  <rect x="40" y="40" width="520" height="320" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1" rx="4"/>
  <text x="300" y="140" text-anchor="middle" fill="white" font-size="28" font-weight="bold" font-family="sans-serif">高级软件工程师</text>
  <text x="300" y="180" text-anchor="middle" fill="rgba(255,255,255,0.7)" font-size="16" font-family="sans-serif">工业和信息化部</text>
  <line x1="200" y1="210" x2="400" y2="210" stroke="rgba(255,255,255,0.4)" stroke-width="1"/>
  <text x="300" y="250" text-anchor="middle" fill="rgba(255,255,255,0.5)" font-size="13" font-family="sans-serif">全国计算机技术与软件专业技术资格</text>
  <text x="300" y="275" text-anchor="middle" fill="rgba(255,255,255,0.5)" font-size="13" font-family="sans-serif">此证书表明持证人具备高级工程师资格</text>
  <text x="300" y="340" text-anchor="middle" fill="rgba(255,255,255,0.4)" font-size="11" font-family="sans-serif">证书编号：XXXX-XXXX-XXXX ｜ 颁发日期：2023 年</text>
</svg>
