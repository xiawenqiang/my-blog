<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 600 400">
  <defs>
    <linearGradient id="g3" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#2c7a47"/>
      <stop offset="100%" stop-color="#42b883"/>
    </linearGradient>
  </defs>
  <rect width="600" height="400" fill="url(#g3)"/>
  <rect x="20" y="20" width="560" height="360" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="2" rx="8"/>
  <rect x="40" y="40" width="520" height="320" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1" rx="4"/>
  <text x="300" y="140" text-anchor="middle" fill="white" font-size="28" font-weight="bold" font-family="sans-serif">Vue 开源贡献者</text>
  <text x="300" y="180" text-anchor="middle" fill="rgba(255,255,255,0.75)" font-size="16" font-family="sans-serif">Vue.js 社区</text>
  <line x1="200" y1="210" x2="400" y2="210" stroke="rgba(255,255,255,0.4)" stroke-width="1"/>
